{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "regions": ["cdg1"],
  "functions": {
    "src/app/api/advisor/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/portfolio-snapshot/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/stripe/webhook/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/portfolio-snapshot",
      "schedule": "0 */6 * * *"
    }
  ]
}
